{
  "name": "@xyflow/ember",
  "version": "0.0.0",
  "description": "Ember Flow - a highly customizable Ember library for building node-based editors, workflow systems, diagrams and more.",
  "keywords": [
    "ember",
    "node-based UI",
    "graph",
    "diagram",
    "workflow",
    "ember-flow",
    "xyflow"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/xyflow/xyflow.git",
    "directory": "packages/ember"
  },
  "homepage": "https://xyflow.com",
  "bugs": {
    "url": "https://github.com/xyflow/xyflow/issues"
  },
  "license": "MIT",
  "scripts": {
    "build": "pnpm build:js && pnpm build:types && pnpm build:css",
    "build:css": "pnpm css",
    "build:js": "rollup --config",
    "build:types": "ember-tsc --declaration --emitDeclarationOnly --noEmit false",
    "css": "postcss src/styles/{base,style}.css --config ./../../tooling/postcss-config --dir dist",
    "dev": "concurrently \"rollup --config --watch --no-watch.clearScreen\" \"pnpm:css-watch\"",
    "css-watch": "pnpm css --watch",
    "lint": "prettier --check .",
    "typecheck": "ember-tsc --noEmit",
    "prepack": "pnpm build"
  },
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./dist/base.css": "./dist/base.css",
    "./dist/style.css": "./dist/style.css",
    "./addon-main.js": "./addon-main.cjs"
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "addon-main.cjs",
    "dist"
  ],
  "dependencies": {
    "@embroider/addon-shim": "^1.8.9",
    "@glimmer/component": "^2.0.0",
    "@glimmer/tracking": "^1.1.2",
    "@xyflow/system": "workspace:*",
    "ember-modifier": "^4.3.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-proposal-decorators": "^7.23.2",
    "@babel/plugin-transform-class-properties": "^7.22.5",
    "@babel/plugin-transform-class-static-block": "^7.22.11",
    "@babel/plugin-transform-typescript": "^7.28.6",
    "@babel/runtime": "^7.28.6",
    "@embroider/addon-dev": "^8.0.0",
    "@glint/ember-tsc": "^1.5.0",
    "@glint/template": "^1.7.7",
    "@rollup/plugin-babel": "^6.0.4",
    "@tsconfig/ember": "3.0.1",
    "autoprefixer": "^10.4.22",
    "babel-plugin-ember-template-compilation": "^3.1.0",
    "concurrently": "^8.2.2",
    "cssnano": "^7.1.2",
    "dotenv": "^17.2.3",
    "ember-source": "~6.11.0",
    "ember-template-imports": "^4.1.1",
    "ember-template-lint": "^7.8.1",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-combine-duplicated-selectors": "^10.0.3",
    "postcss-import": "^16.1.1",
    "postcss-nested": "^7.0.2",
    "postcss-rename": "^0.8.0",
    "prettier": "^3.7.4",
    "prettier-plugin-ember-template-tag": "^2.0.0",
    "rollup": "^4.18.0",
    "rollup-plugin-copy": "^3.5.0",
    "typescript": "~5.9.3"
  },
  "peerDependencies": {
    "ember-source": "~6.11.0",
    "typescript": ">=5.4"
  },
  "ember": {
    "edition": "octane"
  },
  "ember-addon": {
    "app-js": {},
    "main": "addon-main.cjs",
    "type": "addon",
    "version": 2
  },
  "publishConfig": {
    "access": "public"
  }
}
