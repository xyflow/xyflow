{
	"name": "@xyflow/svelte",
	"version": "1.5.2",
	"description": "Svelte Flow - A highly customizable Svelte library for building node-based editors, workflow systems, diagrams and more.",
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"svelte",
		"node-based UI",
		"graph",
		"diagram",
		"workflow",
		"svelte-flow",
		"xyflow"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/xyflow/xyflow.git",
		"directory": "packages/svelte"
	},
	"homepage": "https://svelteflow.dev",
	"bugs": {
		"url": "https://github.com/xyflow/xyflow/issues"
	},
	"scripts": {
		"dev": "concurrently \"svelte-package -o dist/lib -w\" pnpm:css --watch",
		"build": "svelte-package && pnpm run css && publint",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"css": "postcss src/lib/styles/{base,style}.css --config ./../../tooling/postcss-config/ --dir dist ",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		"./package.json": "./package.json",
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		},
		"./dist/base.css": "./dist/base.css",
		"./dist/style.css": "./dist/style.css",
		"./base.css": "./dist/base.css",
		"./style.css": "./dist/style.css"
	},
	"sideEffects": [
		"*.css"
	],
	"files": [
		"dist",
		"src/lib"
	],
	"dependencies": {
		"@svelte-put/shortcut": "^4.1.0",
		"@xyflow/system": "workspace:*"
	},
	"peerDependencies": {
		"svelte": "^5.25.0"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"eslint": "catalog:",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"lightningcss": "^1.32.0",
		"postcss": "^8.5.6",
		"postcss-cli": "^11.0.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"publint": "^0.3.18",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "catalog:",
		"typescript-eslint": "^8.58.1",
		"vite": "catalog:"
	}
}
